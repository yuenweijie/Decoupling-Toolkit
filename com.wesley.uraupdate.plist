<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.wesley.uraupdate</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd "/Users/yuenweijie/Desktop/Co-work Battlefield/Decoupling Calculator/Decoupling Advisory" &amp;&amp; python3 ura_update.py</string>
  </array>
  <!-- Runs Tuesday (Weekday 2) and Friday (Weekday 5) at 19:30, after URA's end-of-day refresh -->
